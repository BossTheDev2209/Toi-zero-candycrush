{
  "name": "toizero",
  "private": true,
  "type": "module",
  "workspaces": ["server", "web"],
  "scripts": {
    "dev": "bun --filter '*' dev",
    "dev:server": "bun --cwd server dev",
    "dev:web": "bun --cwd web dev",
    "build:web": "bun --cwd web build",
    "start": "bun --cwd server start",
    "test": "bun --cwd server test"
  }
}
